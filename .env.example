# Docker group id on host (run: getent group docker | cut -d: -f3)
HOST_DOCKER_GID=999

# Generic development container (Ubuntu-based by default)
DEV_BASE_IMAGE=ubuntu:22.04
DEV_WORKDIR=/workspace/project
PROJECT_PATH=.

# Platform services
GITLAB_IMAGE=gitlab/gitlab-ce:14.9.3-ce.0
ARTIFACTORY_IMAGE=releases-docker.jfrog.io/jfrog/artifactory-oss:6.23.13

# Exposed ports
GITLAB_HTTP_PORT=80
GITLAB_HTTPS_PORT=443
JENKINS_PORT=8080
ARTIFACTORY_PORT=8081
